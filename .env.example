# Copy this to `.env` and fill in real values.
# `scripts/bootstrap.sh` will create `.env` for you if it does not exist.

# Core network settings
TZ=UTC
DOMAIN_NAME=
HOMELAB_HOST_IP=
LOCAL_SUBDOMAIN=*
ACME_EMAIL=admin@example.com

# Opinionated local storage layout.
# Leave this as-is to use the repo's local `./data/media` tree, or change it
# to something like `/mnt/storage/media` to match a real NAS/disk layout.
MEDIA_ROOT=./data/media

# Traefik / TLS mode
# `selfsigned` is the easiest local-first option and is the bootstrap default.
# `cloudflare` uses DNS challenge for real certificates.
# `provided` uses LOCAL_CERT_FILE and LOCAL_CERT_KEY_FILE.
TRAEFIK_TLS_MODE=selfsigned

# Traefik / Cloudflare
CF_DNS_API_TOKEN=
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=
TRAEFIK_DASHBOARD_CREDENTIALS=

# Optional local certificate paths for Traefik.
# Leave blank if you only want ACME certificates.
LOCAL_CERT_FILE=
LOCAL_CERT_KEY_FILE=

# Service credentials
PIHOLE_WEB_PASSWORD=
N8N_PASSWORD=
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=
MINIFLUX_DB_NAME=miniflux
MINIFLUX_DB_USER=miniflux
MINIFLUX_DB_PASSWORD=
PG_USER=jellystat
PG_PASSWORD=
JWT_SECRET=
PGVECTOR_DB=homelab
PGVECTOR_USER=homelab
PGVECTOR_PASSWORD=
LINKWARDEN_PG_PASSWORD=
CODER_POSTGRES_PASSWORD=
SEAFILE_ADMIN_EMAIL=admin@example.com
SEAFILE_ADMIN_PASSWORD=
SEAFILE_DB_ROOT_PASSWORD=
IMMICH_DB_DATABASE_NAME=immich
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=
IMMICH_DB_DATA_LOCATION=./data/immich-db
PHOTO_UPLOAD_LOCATION=./data/photos

# External integrations
NEWT_ID=
NEWT_SECRET=
PANGOLIN_ENDPOINT=
PROD_DOMAIN_NAME=

# Optional services
CODE_SERVER_PASSWORD=
SILVERBULLET_AUTH=
WIREGUARD_ADDRESS=
WIREGUARD_PRIVATE_KEY=
TUBE_USER=
TUBE_PASSWORD=
TA_ELASTIC_PWD=
